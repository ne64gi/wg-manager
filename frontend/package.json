{
  "name": "wg-studio-frontend",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-version": "node ./scripts/sync-version.mjs",
    "dev": "npm run sync-version && vite --host 0.0.0.0 --port 3900",
    "build": "npm run sync-version && tsc -b && vite build",
    "preview": "npm run sync-version && vite preview --host 0.0.0.0 --port 3900",
    "test:e2e": "npm run sync-version && playwright test",
    "test:e2e:headed": "npm run sync-version && playwright test --headed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.74.4",
    "cytoscape": "^3.33.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
